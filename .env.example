ANTHROPIC_DEFAULT_HAIKU_MODEL=bedrock/anthropic.claude-4-5-haiku
SEMANTIC_KERNEL_ENABLED=true
SEMANTIC_KERNEL_PROVIDER=OpenAI
SEMANTIC_KERNEL_MODEL_ID=bedrock/anthropic.claude-4-6-sonnet
