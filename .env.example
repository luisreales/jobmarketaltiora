# Market Intelligence worker behavior
JOBS_MARKET_USE_SEMANTIC_KERNEL=true
JOBS_MARKET_SAMPLING_RATE_PERCENT=100
JOBS_MARKET_MIN_DESCRIPTION_LENGTH=1
JOBS_MARKET_MAX_CALLS_PER_DAY=10000
JOBS_MARKET_PROMPT_VERSION=v1
# Keep this in one line when overriding and preserve placeholders {{Title}} {{Company}} {{Description}}
JOBS_MARKET_PROMPT_TEMPLATE=Analyze this job quickly and return one line: pain=<pain>;category=<category>;confidence=<0-1>. Title={{Title}}. Company={{Company}}. Description={{Description}}

# Optional: external scraper override
UPWORK_SCRAPER_BASE_URL=http://scraper-api:3000
