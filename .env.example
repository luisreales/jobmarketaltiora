FLOW_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..7AWBnlrLwogBqbf9O0PAOXDUvatVstlhrtTIxreREZM
ANTHROPIC_MODEL=bedrock/anthropic.claude-4-6-sonnet
