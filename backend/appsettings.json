        {
          "Term": ".NET backend",
          "Location": "Colombia",
          "Limit": 20
        }
      ]
    },
    "PostProcessing": {
      "IntervalSeconds": 20,
      "BatchSize": 100
    },
    "LinkedIn": {
      "DirectScraping": {
        "ResultLoadTimeoutMs": 20000,
        "DetailLoadTimeoutMs": 12000,
        "ScrollPauseMs": 1200,
        "ClickPauseMs": 600,
        "MaxScrollAttemptsPerPage": 8,
        "MaxPages": 5
      }
    }
  },
  "LinkedInAuth": {
    "LoginHeadless": false,
    "ReuseHeadless": true,
    "NavigationTimeoutMs": 30000,
    "ManualChallengeTimeoutSeconds": 300,
    "SlowMoMs": 50,
    "MaxRetryAttempts": 2,
    "RetryDelayMs": 1500,
    "SessionFilePath": "/app/data/linkedin-state.json"
  },
  "Serilog": {
