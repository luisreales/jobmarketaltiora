    "Providers": {
      "Enabled": ["linkedin", "indeed"]
    },
    "Playwright": {
      "Headless": true,
      "LoginHeadless": false,
      "ManualChallengeTimeoutSeconds": 180,
      "SlowMoMs": 0,
